# Google Cloud OAuth 2.0 access token (cloud-platform scope). Referenced from the
# Authorization header; credproxy swaps the placeholder for the real token at
# TLS egress, so it never enters the agent sandbox.
GOOGLE_CLOUD_ACCESS_TOKEN
# Google Cloud project ID that holds the Firestore database. Non-secret
# identifier injected into the x-goog-user-project header.
GOOGLE_CLOUD_PROJECT
