# Default Kusto/Eventhouse cluster endpoint, e.g.
# https://mycluster.westus.kusto.windows.net. Injected host-side by the
# credstdio bridge; never enters the agent sandbox.
KUSTO_SERVICE_URI
# Default Kusto database name (defaults to NetDefaultDB when unset).
KUSTO_SERVICE_DEFAULT_DB
# Microsoft Fabric API endpoint (defaults to https://api.fabric.microsoft.com/v1).
FABRIC_API_BASE
