# Google Cloud project ID. The Imagen/Veo server terminates at startup if this
# is unset. Injected host-side by the credstdio bridge; never enters the sandbox.
GOOGLE_CLOUD_PROJECT
# Path to a service-account key JSON granting Vertex AI access. Omit only if
# Application Default Credentials are configured host-side. Injected host-side
# by the credstdio bridge; never enters the sandbox.
GOOGLE_APPLICATION_CREDENTIALS
